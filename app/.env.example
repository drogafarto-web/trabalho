# ============================================================================
# Controle de Trabalhos — variáveis de ambiente
# ============================================================================
# Copie este arquivo para `.env.local` (nunca commitado) e preencha os valores.
# Valores aqui são FAKE — sirvem apenas como template.
# ============================================================================

# -----------------------------------------------------------------------------
# Firebase (Web) — seguro expor no cliente, mas proteja com Security Rules
# -----------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=AIzaSyFAKE_REPLACE_ME
VITE_FIREBASE_AUTH_DOMAIN=trabalhos-e0647.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=trabalhos-e0647
VITE_FIREBASE_STORAGE_BUCKET=trabalhos-e0647.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:FAKE

# -----------------------------------------------------------------------------
# Emulators (desenvolvimento local)
# -----------------------------------------------------------------------------
VITE_USE_EMULATORS=true
VITE_EMULATOR_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# Observabilidade (opcional em dev)
# -----------------------------------------------------------------------------
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Flag de ambiente (para comportamento condicional em código)
# -----------------------------------------------------------------------------
# Até criarmos trabalhos-staging, rodamos em modo "staging-mental":
#   - Sem alunos reais
#   - Rules e schemas podem ser reescritos à vontade
#   - SEED de dados fake permitido
# Troque para "production" APENAS quando entrar o primeiro aluno real.
VITE_APP_ENV=staging-mental
