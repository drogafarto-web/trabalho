rules_version = '2';

// =============================================================================
//  Controle de Trabalhos — Firestore Security Rules
// =============================================================================
//  Fase 0: DENY ALL por padrão. Cada coleção libera apenas o mínimo conforme
//  avançamos nas fases (ver docs/01_spec.md e docs/04_schema_json.md).
//
//  Princípios:
//    1. Nada é lido/escrito sem auth (exceto leituras deliberadamente públicas)
//    2. Role é verificado via custom claim (request.auth.token.role)
//    3. Ownership sempre checado server-side (não confiar no cliente)
//    4. Regras são versionadas e têm testes em @firebase/rules-unit-testing
// =============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    //  Helpers
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isProfessor() {
      return isSignedIn()
        && request.auth.token.role == 'professor';
    }

    function isStudent() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isOwner(ownerUid) {
      return isProfessor() && request.auth.uid == ownerUid;
    }

    function isValidTimestamp(ts) {
      return ts is timestamp;
    }

    // -------------------------------------------------------------------------
    //  /professors/{uid}
    //  Documento do professor. Escrita é feita pela Cloud Function
    //  bootstrapProfessorClaim (Admin SDK, bypassa estas rules).
    //  Leitura e atualização de preferências: apenas o dono.
    // -------------------------------------------------------------------------
    match /professors/{uid} {
      allow get: if isProfessor() && request.auth.uid == uid;
      allow list: if false;
      allow create: if false;
      allow update: if isProfessor()
        && request.auth.uid == uid
        && onlyAllowedFieldsUpdated(['preferences', 'lastLoginAt']);
      allow delete: if false;
    }

    function onlyAllowedFieldsUpdated(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // -------------------------------------------------------------------------
    //  /disciplines/{id} — F-PR-04
    //  - Leitura pública: permitida apenas em campos mínimos (name, code,
    //    course, period, semester, deletedAt). O cliente deve projetar.
    //  - Escrita: apenas o dono autenticado como professor.
    //  - Validação leve server-side (detalhe fica na Cloud Function de
    //    criação/update quando passar a valer custom rules sanitizadas).
    // -------------------------------------------------------------------------
    match /disciplines/{id} {
      allow get, list: if true;

      allow create: if isProfessor()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasAll([
             'ownerUid', 'name', 'code', 'course', 'period',
             'semester', 'rubric', 'createdAt', 'updatedAt',
           ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 80
        && request.resource.data.code is string
        && request.resource.data.code.matches('^[A-Z]{3,5}-[0-9]{4}[.][0-9]$');

      allow update: if isOwner('ownerUid')
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isOwner('ownerUid');
    }

    // -------------------------------------------------------------------------
    //  /students/{id} — F-PR-05
    //  Aluno é recurso privado do professor (ownerUid).
    //  Leitura apenas do owner autenticado como professor.
    //  Criação/atualização/exclusão apenas do owner.
    // -------------------------------------------------------------------------
    match /students/{id} {
      allow get, list: if isOwner('ownerUid');

      allow create: if isProfessor()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 80;

      allow update: if isOwner('ownerUid')
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isOwner('ownerUid');
    }

    // -------------------------------------------------------------------------
    //  /discipline_students/{compositeId} — F-PR-05
    //  Junção disciplina <-> aluno. ID composto: {disciplineId}_{studentId}.
    //  - Leitura pública dos campos mínimos (para aluno autocompletar no form
    //    sem login real quando entrar Fase 4)
    //  - Escrita apenas do owner da disciplina
    // -------------------------------------------------------------------------
    match /discipline_students/{id} {
      allow get, list: if true;

      allow create: if isProfessor()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.disciplineId is string
        && request.resource.data.studentId is string;

      allow update: if isOwner('ownerUid');
      allow delete: if isOwner('ownerUid');
    }

    // -------------------------------------------------------------------------
    //  /submissions/{id} — F-AL-01 (create) + F-PR-02/03 (Fase 6)
    //  - Aluno autenticado (anônimo ou não) pode CRIAR com status inicial.
    //  - Validação: tem shortId, disciplineId, students válidos, file, etc.
    //  - Leitura: apenas dono da disciplina (professor).
    //  - Update/delete: apenas dono da disciplina (Fase 6).
    // -------------------------------------------------------------------------
    match /submissions/{id} {
      allow create: if isSignedIn()
        && request.resource.data.status == 'WAITING_FOR_AI'
        && request.resource.data.shortId is string
        && request.resource.data.shortId.matches('^TRAB-[A-Z2-9]{4}$')
        && request.resource.data.disciplineId is string
        && request.resource.data.disciplineOwnerUid is string
        && request.resource.data.students is list
        && request.resource.data.students.size() >= 1
        && request.resource.data.students.size() <= 3
        && request.resource.data.file is map
        && request.resource.data.file.sizeBytes is number
        && request.resource.data.file.sizeBytes > 0
        && request.resource.data.file.sizeBytes <= 47185920  // 45MB
        && request.resource.data.submitter is map;

      allow get, list: if isOwner('disciplineOwnerUid');

      allow update, delete: if isOwner('disciplineOwnerUid');

      match /similarity_matches/{matchId} {
        allow read: if isOwner('disciplineOwnerUid');
        allow write: if false;
      }
    }

    // -------------------------------------------------------------------------
    //  /audit_log/{id}
    //  Imutável. Escrita apenas via Admin SDK (Cloud Functions).
    //  Leitura apenas professor autenticado.
    // -------------------------------------------------------------------------
    match /audit_log/{id} {
      allow get, list: if isProfessor();
      allow create, update, delete: if false;
    }

    // -------------------------------------------------------------------------
    //  /stats/{id}
    //  Agregados pré-computados. Escrita via Cloud Function. Liberado Fase 6.
    // -------------------------------------------------------------------------
    match /stats/{id} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    //  Catch-all — nega qualquer coleção não listada acima.
    //  Proteção contra coleções criadas acidentalmente.
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
