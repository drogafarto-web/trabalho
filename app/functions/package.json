{
  "name": "@trabalho/functions",
  "private": true,
  "version": "0.0.0",
  "description": "Cloud Functions v2 — Controle de Trabalhos",
  "main": "lib/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "set-claim": "node scripts/set-professor-claim.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/genai": "^1.0.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.0",
    "mammoth": "^1.12.0",
    "openai": "^4.77.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9.5.0",
    "react": "^19.2.5",
    "resend": "^6.12.0",
    "svix": "^1.90.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": "22"
  }
}
